{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://impression-backend.vercel.app/api/$1"
    },
    {
      "source": "/blog/(.*)",
      "destination": "https://impression-backend.vercel.app/blog/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
